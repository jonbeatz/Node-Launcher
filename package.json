{
  "name": "vader-project-engine",
  "version": "1.6.0",
  "description": "Vader Project Engine - Jedi Level Dashboard Build v1.6.0",
  "author": "MSC Media",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "vader:dev": "cross-env VPE_LAUNCHER_FORGE=1 concurrently -k --success first \"npm run dev:renderer\" \"npm run dev:main\"",
    "vader:post-dev-forge": "node scripts/vpe-forge-stall-watchdog.cjs launch && node scripts/vpe-forge-pause.cjs && npm run vpe:take-state-snapshot && npm run vpe:check-readiness && npm run build:win && npm run vpe:cleanup-dist",
    "vader:force-forge": "node scripts/vpe-forge-stall-watchdog.cjs launch && node scripts/vpe-forge-pause.cjs && npm run vpe:take-state-snapshot && npm run vpe:check-readiness && npm run build:win && npm run vpe:cleanup-dist",
    "vpe:cleanup-dist": "node scripts/msc-cleanup-dist.cjs",
    "vader:dev-to-forge": "npm run vader:dev && npm run vader:post-dev-forge",
    "vader:sync": "npm run vader:dev -- --success last && npm run vader:post-dev-forge",
    "vader:clean-sync": "node scripts/vpe-clean-sync.cjs",
    "vpe:force-clear": "taskkill /F /IM node.exe /T /FI \"MEMUSAGE gt 1000\" || node -e \"process.exit(0)\"",
    "vpe:take-state-snapshot": "node scripts/vpe-prebuild-snapshot.cjs",
    "vpe:check-readiness": "node scripts/vpe-syntax-guard.cjs",
    "dev:main": "electron . --remote-debugging-port=9222",
    "start": "electron . --remote-debugging-port=9222",
    "dev:renderer": "next dev src/renderer -p 3000",
    "build": "npm run build:main",
    "build:win": "npm run build:main",
    "prebuild:main": "node scripts/msc-copy-release-icon.cjs && npm run build:renderer",
    "build:main": "node scripts/msc-run-electron-builder.cjs",
    "build:renderer": "next build src/renderer",
    "lint": "next lint src/renderer",
    "test:e2e": "playwright test",
    "test:e2e:electron": "npm run build:renderer && playwright test --config=playwright.electron.config.ts",
    "repair:ast": "node scripts/vpe-repair-stub.cjs",
    "rebuild:natives": "electron-rebuild -f -o better-sqlite3"
  },
  "dependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.3",
    "@babel/traverse": "^7.29.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-aspect-ratio": "^1.0.3",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-collapsible": "^1.0.3",
    "@radix-ui/react-context-menu": "^2.1.5",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-hover-card": "^1.0.7",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-menubar": "^1.0.4",
    "@radix-ui/react-navigation-menu": "^1.1.4",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-toggle": "^1.0.3",
    "@radix-ui/react-toggle-group": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@vercel/analytics": "^2.0.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ast-types": "^0.16.1",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "electron-is-dev": "^2.0.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^11.18.2",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.14.0",
    "next": "15.5.12",
    "next-themes": "^0.2.1",
    "node-pty": "^1.1.0",
    "pm2": "^5.3.1",
    "prism-react-renderer": "^2.4.1",
    "puppeteer-core": "^21.11.0",
    "react": "19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.75.0",
    "react-live": "^4.1.8",
    "react-resizable-panels": "^4.11.0",
    "recast": "^0.23.11",
    "recharts": "^3.8.1",
    "sonner": "^1.3.1",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7",
    "tree-kill": "^1.2.2",
    "tw-animate-css": "^1.4.0",
    "vaul": "^0.8.0",
    "xterm": "^5.3.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.5.12",
    "postcss": "^8.5.14",
    "rcedit": "^5.0.2",
    "rimraf": "^6.1.2",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.3.3"
  },
  "build": {
    "appId": "com.vader.projectengine",
    "productName": "Vader Project Engine",
    "afterPack": "scripts/msc-after-pack-embed-icon.cjs",
    "copyright": "Copyright © MSC Media",
    "icon": "media/icon.ico",
    "forceCodeSigning": false,
    "npmRebuild": false,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!src/renderer/app{,/**/*}",
      "!src/renderer/components{,/**/*}",
      "!src/renderer/hooks{,/**/*}",
      "!src/renderer/lib{,/**/*}",
      "!src/renderer/styles{,/**/*}",
      "!src/renderer/*.{ts,tsx}",
      "!src/renderer/.eslintrc.json",
      "!src/renderer/tsconfig.json",
      "!src/renderer/tsconfig.tsbuildinfo",
      "!src/renderer/next-env.d.ts",
      "!src/renderer/.next{,/**/*}",
      "!e2e{,/**/*}",
      "!playwright.config.ts",
      "!playwright.electron.config.ts",
      "!scripts{,/**/*}",
      "!mcps{,/**/*}",
      "!.cursor{,/**/*}",
      "!_design_references{,/**/*}",
      "!dist{,/**/*}",
      "!**/*.{md,MD}"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*",
      "**/node_modules/node-pty/**/*",
      "**/node_modules/pm2/**/*"
    ],
    "extraResources": [
      {
        "from": "media/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "icon": "media/icon.ico",
      "executableName": "Vader Project Engine",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "Vader Project Engine.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Vader Project Engine",
      "uninstallDisplayName": "Vader Project Engine",
      "installerIcon": "media/icon.ico",
      "uninstallerIcon": "media/icon.ico"
    }
  }
}
