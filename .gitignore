# dependencies
node_modules/

# Git LFS (optional): run `git lfs install` once per machine. This repo does not ship a
# .gitattributes LFS map yet; if pushes fail on ghost LFS objects from old history, use:
#   git config --local lfs.allowmissingghostobjects true

# next / build artifacts
.next/
# Repo-root `out/` only (not `src/renderer/out`).
/out/
# Next static export for Electron — regenerated by `npm run build:renderer` (also runs in `prebuild:main`).
src/renderer/out/
**/*.tsbuildinfo
dist/
# build/ = electron-builder `buildResources` (optional NSIS assets); app icon lives in media/icon.ico.
coverage/

# playwright (electron e2e)
/test-results/
/playwright-report/
/blob-report/

# electron / bundler caches
.turbo/
.cache/
cache/
cache/thumbnails/

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# temporary/runtime data
*.tmp
*.temp
*.pid

# intentional repo content (keep tracked)
# - `.cursor/`, `vpe-backups/`, media/icon.ico, media/_vpe_archive/ (if present), vault placeholders (.gitkeep, .vpe_keep)
# - media/vault raster assets (.jpg/.jpeg/.png/.webp), vpe-version.lock, and src/main/db/*.sqlite (+ engine JSON) are tracked (operator policy)
# - _design_references/: layout / UI reference snapshots (see .cursorignore for indexer only)

# Sovereign catalog DB (LOGIC_MOD_01) — local `data/` at repo or install root; keep folder via `.gitkeep` only.
/data/*
!/data/.gitkeep

# Portable dev profile: SQLite + full Chromium userData (Code Cache, Session Storage, …). Never commit.
vpe-local-data/

# Repo `.cursor/` (rules, prompts, docs, hooks) and `vpe-backups/` (catalog DB snapshots) are tracked — do not add ignore lines for them here.

.playwright-mcp/

# Google API workspace — tracked: config + launcher scripts; secrets stay local
google-api/*
!google-api/litellm_config.yaml
!google-api/ngrok.exe
!google-api/vpe-start-api.ps1
!google-api/README.md
# Legacy root paths (if old copies remain)
gcp_key.json
/litellm_config.yaml